<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent for the local Garmin sync.

  Replace __NODE_BIN__ with the output of `which node` and __PROJECT_DIR__ with
  the absolute path to this repository, then install it:

    sed -e "s|__NODE_BIN__|$(which node)|" -e "s|__PROJECT_DIR__|$PWD|" \
      scripts/com.life-manager.garmin-sync.plist \
      > ~/Library/LaunchAgents/com.life-manager.garmin-sync.plist
    launchctl load ~/Library/LaunchAgents/com.life-manager.garmin-sync.plist

  Note: launchd resolves these paths at load time. If the repository moves, the
  job fails with MODULE_NOT_FOUND until it is regenerated and reloaded.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.life-manager.garmin-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>__NODE_BIN__</string>
        <string>__PROJECT_DIR__/scripts/garmin-sync.mjs</string>
        <string>3</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- Poll every 30 min for near-live data. Cached OAuth tokens make this a
         cheap refresh instead of a full SSO login on every run. -->
    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/garmin-sync.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/garmin-sync.log</string>
</dict>
</plist>
